{
    "name": "drupal/pantheon_content_publisher",
    "type": "drupal-module",
    "description": "Pantheon Content Publisher",
    "keywords": ["Drupal"],
    "license": "GPL-2.0+",
    "homepage": "https://www.drupal.org/project/pantheon_content_publisher",
    "authors": [
        {
            "name": "ghost of drupal past",
            "homepage": "https://www.drupal.org/u/ghost-of-drupal-past",
            "role": "Maintainer"
        }
    ],
    "repositories": [
        {
            "type": "composer",
            "url": "https://packages.drupal.org/8"
        }
         ],
    "require": {
        "drupal/search_api": "^1.0",
        "drupal/media_library_form_element": "^2.1",
        "drupal/imagecache_external": "^3.0",
        "dpauli/graphql-request-builder": "^1.0",
        "drupal/key": "^1.20"
    },
    "require-dev": {
        "drupal/coder": "^8.3",
        "squizlabs/php_codesniffer": "^3.4"
    },
    "scripts": {
        "code:lint": [
            "vendor/bin/phpcs --config-set installed_paths vendor/drupal/coder/coder_sniffer",
            "vendor/bin/phpcs --ignore=vendor,.github . "
        ],
        "code:fix": [
            "vendor/bin/phpcs --config-set installed_paths vendor/drupal/coder/coder_sniffer",
            "vendor/bin/phpcbf . --ignore=vendor src"
        ],
        "pre-commit": [
            "composer validate --strict",
            "@code:fix",
            "@code:lint"
        ]
    },
    "support": {
        "issues": "https://www.drupal.org/project/issues/pantheon_content_publisher",
        "source": "http://cgit.drupalcode.org/pantheon_content_publisher"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
